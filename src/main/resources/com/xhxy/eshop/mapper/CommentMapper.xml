<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xhxy.eshop.mapper.CommentMapper">
	<cache/>
	<resultMap id="CommentResultMap" type="com.xhxy.eshop.entity.Comment">
		<id property="id" column="id"/>
		<result property="content" column="content"/>
		<result property="createTime" column="createtime"/>
		<association property="user" javaType="com.xhxy.eshop.entity.User">
			<id property="id" column="user_id"/>
			<result property="username" column="username"/>
		</association>
		<association property="blog" javaType="com.xhxy.eshop.entity.Blog">
			<id property="id" column="blog_id"/>
		</association>
	</resultMap>
	
	<select id="findByBlogId" resultMap="CommentResultMap">
		select c.id, c.content, c.createtime, c.blog_id, c.user_id, u.username 
		from comment c 
		left join user u on c.user_id = u.id 
		where c.blog_id = #{blogId}
	</select>
	<insert id="save" parameterType="com.xhxy.eshop.entity.Comment">
		insert into comment(content,createtime,blog_id,user_id) values(#{content},#{createTime},#{blog.id},#{user.id})
	</insert>
</mapper>
