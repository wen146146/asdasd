<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xhxy.eshop.mapper.CommentMapper">
	<select id="findByBlogId" resultType="com.xhxy.eshop.entity.Comment">
		select id, content, createtime, blog_id, user_id from comment where blog_id = #{blogId}
	</select>
	<insert id="save" parameterType="com.xhxy.eshop.entity.Comment">
		insert into comment(content,createtime,blog_id,user_id) values(#{content},#{createtime},#{blog.id},#{user.id})
	</insert>
</mapper>
