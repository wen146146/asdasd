<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xhxy.eshop.mapper.EvaluationMapper">
	<select id="findByProductId" resultType="com.xhxy.eshop.entity.Evaluation">
		select id, content, score, createtime, product_id, user_id from evaluation where product_id = #{productId}
	</select>
</mapper>
