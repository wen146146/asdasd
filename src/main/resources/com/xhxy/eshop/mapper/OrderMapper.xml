<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xhxy.eshop.mapper.OrderMapper">
	<select id="getByUserId" resultType="com.xhxy.eshop.entity.Order">
		select id, user_id, address_id, total, status, createtime from orders where user_id = #{userId}
	</select>
	<select id="findById" resultType="com.xhxy.eshop.entity.Order">
		select id, user_id, address_id, total, status, createtime from orders where id = #{orderId}
	</select>
	<insert id="saveFromCart">
		insert into orders(user_id,address_id,total,status,createtime) values(#{cart.user.id},#{address.id},#{cart.total},'pending',now())
	</insert>
	<insert id="save" parameterType="com.xhxy.eshop.entity.Order">
		insert into orders(user_id,total,address_id,status,createtime) values(#{user.id},#{total},#{address.id},#{status},#{createTime})
	</insert>
</mapper>
